# Copy to .env (gitignored) and fill in. Bun auto-loads .env at daemon startup.

# Optional free AI (Smart Commit + AI commit messages). Get a Groq key in 3 clicks:
#   1. https://console.groq.com/keys  →  sign in
#   2. Create API Key  →  Copy
#   3. uncomment the line below and paste it in (the free tier is plenty)
# REPOYETI_BUILTIN_GROQ_KEY=gsk_your_key_here

# Optional: override the model (defaults to llama-3.1-8b-instant).
# REPOYETI_BUILTIN_GROQ_MODEL=llama-3.1-8b-instant
