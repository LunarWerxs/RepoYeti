# Copy to .env (gitignored) and fill in. Bun auto-loads .env at daemon startup.

# Free built-in Groq key so AI commit messages work with zero setup.
# Get a free key at https://console.groq.com/keys — it's an intentionally throwaway key.
GITMOB_BUILTIN_GROQ_KEY=gsk_your_throwaway_groq_key_here

# Optional: override the built-in model (defaults to llama-3.1-8b-instant).
# GITMOB_BUILTIN_GROQ_MODEL=llama-3.1-8b-instant
